# AI Customer Finder Environment Variables
# Copy this file to .env and fill in your API keys

# ===================================
# REQUIRED: Search API Configuration
# ===================================
# Get your API key from: https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# ===================================
# OPTIONAL: LLM Configuration (via litellm)
# ===================================
# Set LLM_MODEL to any model supported by litellm.
# litellm uses a "provider/model" format. Leave empty to disable LLM features.
#
# ---- International providers ----
# OpenAI:       LLM_MODEL=openai/gpt-4o-mini
# Anthropic:    LLM_MODEL=anthropic/claude-3-haiku-20240307
# Google:       LLM_MODEL=gemini/gemini-1.5-flash
# OpenRouter:   LLM_MODEL=openrouter/google/gemma-3-27b-it:free
# Grok (xAI):   LLM_MODEL=xai/grok-3-mini-beta
#
# ---- Domestic providers (国内推荐) ----
# DeepSeek:     LLM_MODEL=deepseek/deepseek-chat
# Zhipu GLM:    LLM_MODEL=zhipuai/glm-4-flash
# MiniMax:      LLM_MODEL=minimax/abab6.5s-chat
# Volcano/豆包: LLM_MODEL=volcengine/doubao-1-5-pro-256k-250115
#
LLM_MODEL=

# API Keys — only set the key for your chosen provider
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=

# Zhipu GLM (https://open.bigmodel.cn)
ZHIPUAI_API_KEY=

# MiniMax (https://platform.minimaxi.com)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Grok / xAI (https://console.x.ai)
XAI_API_KEY=

# Volcano Engine / 火山引擎豆包 (https://console.volcengine.com/ark)
VOLCENGINE_API_KEY=
VOLCENGINE_API_BASE=https://ark.cn-beijing.volces.com/api/v3

# ===================================
# Browser Configuration
# ===================================
# Run browser in headless mode (true/false)
HEADLESS=true

# Page load timeout in milliseconds
TIMEOUT=15000

# Whether to visit contact pages for more info (true/false)
VISIT_CONTACT_PAGE=false