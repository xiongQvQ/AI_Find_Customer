{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Hunter",
  "version": "1.0.0",
  "identifier": "app.aihunter.desktop",
  "build": {
    "frontendDist": "../../../frontend/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI Hunter",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../dist/AIHunter": "resources/AIHunter"
    },
    "macOS": {
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "nsis": {
      "displayLanguageSelector": false,
      "languages": ["SimpChinese", "English"],
      "installerIcon": "icons/icon.ico",
      "headerImage": null,
      "sidebarImage": null,
      "installMode": "currentUser",
      "shortcuts": [
        {
          "location": "Desktop",
          "name": "AI Hunter"
        },
        {
          "location": "StartMenu",
          "name": "AI Hunter"
        }
      ]
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
