# ============================================================
# AI Hunter — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- LLM Model (litellm format: "provider/model") ---
# Examples:
#   gpt-4o                              (OpenAI)
#   anthropic/claude-3-5-sonnet-20241022 (Anthropic)
#   openrouter/google/gemini-pro        (OpenRouter)
#   groq/llama-3.3-70b-versatile        (Groq)
#   zai/glm-4.7                         (GLM / 智谱 Z.AI)
#   moonshot/moonshot-v1-128k           (Kimi / Moonshot)
#   minimax/MiniMax-M2.1-highspeed      (MiniMax, recommended default)
LLM_MODEL=minimax/MiniMax-M2.1-highspeed
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# --- Reasoning Model (for ReAct agent decision-making) ---
# Uses stronger reasoning model for tool-use decisions.
# Examples: gpt-4o, anthropic/claude-3-5-sonnet-20241022, openrouter/deepseek/deepseek-r1
REASONING_MODEL=minimax/MiniMax-M2.5
REASONING_TEMPERATURE=0.2
REASONING_MAX_TOKENS=4096

# --- LLM Provider API Keys (fill in the ones you use) ---
# Recommended default:
#   LLM_MODEL=minimax/MiniMax-M2.1-highspeed
#   REASONING_MODEL=minimax/MiniMax-M2.5
# Apply for MiniMax keys in the MiniMax platform dashboard, then paste them here.
# Base URL guidance:
#   International: https://api.minimax.io/v1
#   China mainland: https://api.minimaxi.com/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
ZAI_API_KEY=
MOONSHOT_API_KEY=
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io/v1

# --- Search ---
# Google Maps search: ALWAYS uses Serper (required if you want Maps results)
SERPER_API_KEY=        # https://serper.dev — dedicated to Google Maps search

# General web search: Tavily (primary) → Serper (fallback)
# Tavily supports multiple API keys (comma-separated) for round-robin rotation.
# Strongly recommended for higher-volume hunts: apply for 2-3 keys and join them with commas.
# Example:
#   TAVILY_API_KEY=tvly-dev-xxx,tvly-prod-yyy,tvly-prod-zzz
TAVILY_API_KEY=        # https://tavily.com — e.g. key1,key2,key3

JINA_API_KEY=          # https://jina.ai (web scraping / Jina Reader)

# --- Email ---
# Email automation is intentionally disabled in the current OSS build.

# --- Langfuse (observability, optional) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_ENABLED=false

# --- Hunt Defaults ---
DEFAULT_TARGET_LEAD_COUNT=200
DEFAULT_MAX_ROUNDS=10
DEFAULT_KEYWORDS_PER_ROUND=8
MIN_NEW_LEADS_THRESHOLD=5

# --- Concurrency ---
SEARCH_CONCURRENCY=10
SCRAPE_CONCURRENCY=5
EMAIL_GEN_CONCURRENCY=3
REACT_MAX_ITERATIONS=5

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
API_ACCESS_TOKEN=
SETTINGS_API_ENABLED=false

# --- Database ---
CHECKPOINT_DB_PATH=hunt_sessions.db

# --- File Upload ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
